# Bat files must always have CRLF for Windows compatibility
*.bat text eol=crlf

# Shell scripts must always have LF
*.sh text eol=lf
*.command text eol=lf

# YAML/JSON/Markdown: normalize to LF
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Python: normalize to LF
*.py text eol=lf
